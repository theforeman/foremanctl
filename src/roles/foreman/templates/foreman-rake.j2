#!/bin/bash

validate_actions() {
    # This list is generated by running:
    # rg '# foreman-rake' | awk '{ print $3 }' | sort -u
    # against the foreman documentation repository (https://github.com/theforeman/foreman-documentation).
    # The intention is to have a list of tasks that were mentioned explicitly in the documentation.
    local allowed_actions=(
        "audits:anonymize"
        "audits:expire"
        "audits:list_attributes"
        "console"
        "facts:clean"
        "foreman_openscap:bulk_upload:default"
        "foreman_tasks:cleanup"
        "interfaces:clean"
        "katello:delete_orphaned_content"
        "katello:upgrade_check"
        "ldap:refresh_usergroups"
        "orchestration:dhcp:add_missing"
        "orchestration:dhcp:remove_offending"
        "permissions:reset"
        "reports:daily"
        "reports:expire"
        "reports:monthly"
        "reports:weekly"
        "telemetry:metrics"
        "templates:cleanup"
    )

    local joined_pattern
    joined_pattern=$(IFS="|"; echo "${allowed_actions[*]}")

    local pattern="(^|[[:space:]])($joined_pattern)([[:space:]]|$)"

    if [[ ! "$*" =~ $pattern ]]; then
        if [ "${ALLOW_UNSUPPORTED}" != "true" ]; then
            echo "ERROR: Unsupported action detected." >&2
            exit 1
        else
            echo "WARNING: Unsupported action detected. Please use with caution." >&2
        fi
    fi
}

if [ "$(id -u)" -ne 0 ]; then
    echo "This script must be run as root" >&2
    exit 1
fi

validate_actions "$@"

# Use an array to avoid shell expansion issues
TTY_ARGS=()
if [ -t 0 ]; then
    TTY_ARGS=(-it)
fi

exec podman exec "${TTY_ARGS[@]}" {{ foreman_container_name }} foreman-rake "$@"
